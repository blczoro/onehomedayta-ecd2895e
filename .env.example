# Browser (Vite, public) — required
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_ANON_OR_PUBLISHABLE_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT"

# Server (server functions / SSR) — required
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="YOUR_ANON_OR_PUBLISHABLE_KEY"
SUPABASE_PROJECT_ID="YOUR-PROJECT"

# Admin / setup scripts only — KEEP SECRET, never expose to the client
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
